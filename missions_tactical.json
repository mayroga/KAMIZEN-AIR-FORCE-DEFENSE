{
  "sys": "KAMIZEN NEURO-COGNITIVE TACTICAL READINESS PLATFORM",
  "version": "DOD-736-SFS-ADAPTIVE-v4",
  "classification": "SIMULATED TRAINING ENVIRONMENT - HUMAN PERFORMANCE OPTIMIZATION",

  "engine_config": {
    "adaptive_stress_engine": true,
    "real_time_telemetry": true,
    "session_persistence": true,
    "behavioral_analytics": true,
    "roe_scoring_model": "WEIGHTED_MULTIVARIATE_V2",
    "difficulty_scaling": "ADAPTIVE_DYNAMIC",
    "instructor_dashboard": true
  },

  "telemetry_schema": {
    "reaction_time_ms": 0,
    "decision_latency_ms": 0,
    "stress_index": 0,
    "cognitive_load": 0,
    "focus_stability": 0,
    "breathing_regulation": 0,
    "roe_compliance": 0,
    "hesitation_index": 0,
    "adaptation_rate": 0
  },

  "scoring_model": {
    "cognitive_readiness": 0,
    "stress_resilience": 0,
    "decision_accuracy": 0,
    "operational_discipline": 0,
    "situational_awareness": 0,
    "adaptive_performance_index": 0
  },

  "rules": [
    "Performance is measured under cognitive load variance",
    "Stress is dynamically simulated and adaptive",
    "Decision quality is weighted over speed under escalation",
    "ROE compliance overrides all performance metrics",
    "Recovery speed is a core readiness indicator"
  ],

  "missions": [

    {
      "id": 1,
      "cat": "baseline_calibration",
      "difficulty": 1,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 1: NEUROLOGICAL BASELINE ESTABLISHMENT" }
        },

        {
          "story": {
            "en": "Operator baseline is measured under minimal cognitive load to establish physiological reference metrics."
          }
        },

        {
          "t": "breath_auto",
          "d": 25,
          "tx": { "en": "RESPIRATORY STABILIZATION PHASE" },
          "inf": { "en": "Establish baseline HRV and parasympathetic control." }
        },

        {
          "t": "telemetry_tick",
          "data": {
            "stress_index": 10,
            "cognitive_load": 15
          }
        },

        {
          "t": "r",
          "tx": { "en": "BASELINE ESTABLISHED" },
          "p": 50
        }

      ]
    },

    {
      "id": 2,
      "cat": "controlled_cognition",
      "difficulty": 2,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 2: CONTROLLED COGNITIVE RESPONSE" }
        },

        {
          "story": {
            "en": "First adaptive variables introduced. Reaction under mild uncertainty is evaluated."
          }
        },

        {
          "t": "d",
          "q": { "en": "VISUAL INPUT IS PARTIALLY OBSCURED. IDENTIFICATION STRATEGY?" },
          "op": [
            "WAIT FOR CLARITY",
            "REQUEST ADDITIONAL DATA",
            "GUESS BASED ON PATTERN",
            "IGNORE INPUT"
          ],
          "c": 1,
          "ex": ["Data acquisition is prioritized over assumption under uncertainty."]
        },

        {
          "t": "telemetry_tick",
          "data": {
            "stress_index": 18,
            "cognitive_load": 22,
            "reaction_time_ms": 980
          }
        }

      ]
    },

    {
      "id": 3,
      "cat": "stress_introduction",
      "difficulty": 3,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 3: INITIAL STRESS EXPOSURE" }
        },

        {
          "story": {
            "en": "System introduces auditory and visual interference to evaluate stability under stress noise."
          }
        },

        {
          "t": "stress_event",
          "payload": {
            "audio_noise": "RADIO_STATIC_LOW",
            "visual_flicker": true
          }
        },

        {
          "t": "sil",
          "d": 20,
          "tx": { "en": "FOCUS MAINTENANCE PHASE" }
        },

        {
          "t": "telemetry_tick",
          "data": {
            "stress_index": 35,
            "focus_stability": 70
          }
        }

      ]
    },

    {
      "id": 4,
      "cat": "roe_decision_pressure",
      "difficulty": 4,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 4: ROE DECISION UNDER AMBIGUITY" }
        },

        {
          "d",
          "q": { "en": "ENTITY PRESENTS AMBIGUOUS BEHAVIOR IN RESTRICTED ZONE. RESPONSE?" },
          "op": [
            "ESCALATE IMMEDIATELY",
            "COLLECT ADDITIONAL INFORMATION",
            "IGNORE AND CONTINUE",
            "AUTOMATIC NEUTRALIZATION"
          ],
          "c": 1,
          "ex": ["ROE prioritizes confirmation before escalation."]
        },

        {
          "t": "telemetry_tick",
          "data": {
            "roe_compliance": 88,
            "hesitation_index": 40
          }
        }

      ]
    },

    {
      "id": 5,
      "cat": "multi_task_load",
      "difficulty": 5,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 5: MULTI-STREAM COGNITIVE LOAD" }
        },

        {
          "story": {
            "en": "Operator must process simultaneous inputs under increasing cognitive demand."
          }
        },

        {
          "t": "stress_event",
          "payload": {
            "multi_input": true,
            "time_pressure": true
          }
        },

        {
          "t": "telemetry_tick",
          "data": {
            "cognitive_load": 60,
            "reaction_time_ms": 1200,
            "focus_stability": 62
          }
        }

      ]
    },

    {
      "id": 6,
      "cat": "anomaly_detection",
      "difficulty": 6,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 6: BEHAVIORAL ANOMALY DETECTION" }
        },

        {
          "d",
          "q": { "en": "SUBJECT BEHAVIOR DEVIATES FROM ENVIRONMENTAL NORM. CLASSIFICATION?" },
          "op": [
            "NORMAL VARIATION",
            "POTENTIAL THREAT SIGNAL",
            "IGNORE",
            "INSUFFICIENT DATA"
          ],
          "c": 1
        },

        {
          "t": "telemetry_tick",
          "data": {
            "anomaly_detection_accuracy": 85
          }
        }

      ]
    },

    {
      "id": 7,
      "cat": "adaptive_stress_escalation",
      "difficulty": 7,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 7: ADAPTIVE STRESS ESCALATION SYSTEM" }
        },

        {
          "adaptive_event",
          "rules": {
            "if_performance_high": "increase_complexity",
            "if_performance_low": "increase_time_pressure"
          }
        },

        {
          "t": "telemetry_tick",
          "data": {
            "stress_index": 72,
            "adaptation_rate": 68
          }
        }

      ]
    },

    {
      "id": 8,
      "cat": "branching_scenario_logic",
      "difficulty": 8,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 8: BRANCHING DECISION SIMULATION" }
        },

        {
          "story": {
            "en": "System dynamically generates scenario branches based on operator performance history."
          }
        },

        {
          "t": "d",
          "q": { "en": "MULTIPLE CONCURRENT THREATS DETECTED. PRIORITIZATION?" },
          "op": [
            "FASTEST RESPONSE",
            "HIGHEST RISK TARGET",
            "MOST INFORMATION GAIN",
            "RANDOM SELECTION"
          ],
          "c": 1
        }

      ]
    },

    {
      "id": 9,
      "cat": "full_simulation_integration",
      "difficulty": 9,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 9: FULL SYSTEM INTEGRATION SIMULATION" }
        },

        {
          "stress_event",
          "payload": {
            "audio_noise": "RADIO_CHATTER_HIGH",
            "visual_clutter": true,
            "time_pressure": true,
            "conflicting_inputs": true
          }
        },

        {
          "t": "telemetry_tick",
          "data": {
            "stress_index": 90,
            "cognitive_load": 88,
            "roe_compliance": 92
          }
        }

      ]
    },

    {
      "id": 10,
      "cat": "final_readiness_validation",
      "difficulty": 10,

      "b": [

        {
          "t": "v",
          "tx": { "en": "MISSION 10: OPERATIONAL READINESS VALIDATION" }
        },

        {
          "story": {
            "en": "Final evaluation aggregates all behavioral, cognitive, and stress performance metrics into readiness index."
          }
        },

        {
          "t": "telemetry_tick",
          "data": {
            "final_readiness_score": 94,
            "adaptive_performance_index": 91,
            "stress_resilience": 89,
            "decision_accuracy": 93
          }
        },

        {
          "t": "r",
          "tx": { "en": "OPERATOR CLEARED FOR SIMULATION DEPLOYMENT" },
          "p": 1000
        }

      ]
    }

  ]
}
